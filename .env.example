RABBIT_USER=user
RABBIT_PASS=change-me
RABBIT_URL=amqp://user:change-me@rabbitmq:5672/
MASTER_KEY_HEX=replace-with-64-hex-chars
PUBLIC_BASE_URL=http://localhost
METRICS_PORT=9100
MAILER_TRANSPORT=smtp
MAILER_LOG_BODY=false
SMTP_HOST=smtp.mail.ru
SMTP_PORT=465
SMTP_USERNAME=change-me@mail.ru
SMTP_PASSWORD=change-me
SMTP_FROM="Signer <change-me@mail.ru>"
SMTP_TLS_MODE=implicit
SMTP_SERVER_NAME=
HTTP_READ_HEADER_TIMEOUT=5s
HTTP_READ_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=120s
HTTP_IDLE_TIMEOUT=60s
SHUTDOWN_TIMEOUT=15s
DEPENDENCY_TIMEOUT=30s
PDFSIGN_TIMEOUT=60s
UPLOAD_MAX_BYTES=10485760
JSON_MAX_BYTES=1048576
PDFSIGNER_MAX_FILE_SIZE=10MB
PDFSIGNER_MAX_REQUEST_SIZE=11MB
PDFSIGNER_MAX_HEADER_SIZE=16KB
